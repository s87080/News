<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="News.NewsPages.SelectCity"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BgColor}"
             Title="SelectCity"
             Shell.TabBarIsVisible="False">
   
        <Grid RowDefinitions="Auto,Auto,*,Auto">
          <Frame CornerRadius="25"
               Grid.Row="0"
               BackgroundColor="{StaticResource SearchBg}"
               Padding="8,8"
               HasShadow="False"
               Margin="10,10">

            <Grid ColumnDefinitions="Auto,*"
                  VerticalOptions="Center">

                <!-- SEARCH ICON -->
                <Image Source="search.png"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center"
                       Margin="5,0"/>

                <!-- SEARCH ENTRY -->
                <Entry Grid.Column="1"
                       Placeholder="Search city..."
                       BackgroundColor="Transparent"
                       FontSize="16"
                       Margin="10,0,0,0"/>

            </Grid>
            

          </Frame>
            <BoxView HeightRequest="1"
                     Grid.Row="1"/>
                <Grid Grid.Row="2" Padding="15">
                    <CollectionView x:Name="CityData"
                            >
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                 <Grid RowDefinitions="Auto,Auto" >
                           
                                        <HorizontalStackLayout Grid.Row="0"
                                               Spacing="10"
                                               Padding="10">
                                            <Image Source="mouse.png" 
                                                    HeightRequest="22"
                                                    WidthRequest="22">
                                
                                            </Image>
                                         <Label
                                            Text="{Binding CityName}"
                                            TextColor="Black"/>
                                            
                                        </HorizontalStackLayout>
                                            <BoxView Grid.Row="1"
                                             HeightRequest="1"
                                            />
                            
                                 </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>




                </Grid>

                <Button Grid.Row="3"
                        Text="Next"
                        BackgroundColor="{StaticResource News}"
                        TextColor="White"
                        FontSize="20"
                        FontAttributes="Bold"
                        CornerRadius="30"
                        HeightRequest="60"
                        WidthRequest="150"
                        HorizontalOptions="Center"
                        Margin="0,20,0,0"
                        Clicked="Next"
                        >

                        <Button.Shadow>
                            <Shadow Brush="#40000000"
                                    Offset="0,5"
                                    Radius="10"
                                    Opacity="0.8"/>
                        </Button.Shadow>

                </Button>
        </Grid>
        
        
    
</ContentPage>