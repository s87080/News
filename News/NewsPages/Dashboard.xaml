                    </Grid>

                </Grid>
            </Grid>


            <!-- Option 8 -->
            <Grid Grid.Row="8" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">

                <!--IMAGE SECTION-->
                <Image Source="relaiablesourses.png" Aspect="AspectFit" Grid.Row="0"></Image>

                <!--TEXT-->
