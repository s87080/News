                <!--LIKE COMMENT SHARE-->
                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Padding="0,8">
                    <Grid Grid.Column="0" ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="20" HorizontalOptions="Start">
