<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="News.NewsPages.Password"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BgColor}"
             Title="Password"
             Shell.TabBarIsVisible="False">
    
    <VerticalStackLayout>
        <Grid RowDefinitions="Auto,Auto,Auto,auto">
            <Grid Grid.Row="0"
                  ColumnDefinitions="Auto,Auto,Auto"
                  HorizontalOptions="Center"
                  VerticalOptions="Center">

                <!-- IMAGE -->
                <Image Source="nw.png"
                       Grid.Column="0"
                       HeightRequest="120"
                       VerticalOptions="Center"
                       Margin="0,0,0,0"/>

                <!-- NEWS TEXT -->
                <Label Grid.Column="1"
                       Text="News"
                       TextColor="{StaticResource News}"
                       VerticalOptions="Center"
                       FontAttributes="Bold"
                       FontSize="30"
                       Margin="-15,0,0,0"/>

                <!-- WATCH TEXT -->
                <Label Grid.Column="2"
                       Text="Watch"
                       TextColor="{StaticResource Watch}"
                       VerticalOptions="Center"
                       FontAttributes="Bold"
                       FontSize="30"/>

            </Grid>

           

            
            <Grid Grid.Row="1"
                  Padding="20,0,20,20">

                    <Label
                    Text="Forget Password"
                    TextColor="{StaticResource News}"
                    HorizontalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="20"/>
            </Grid>
            
            <!--ENTRY SECTION-->
            <Grid Grid.Row="2"
                  RowDefinitions="Auto,Auto,auto,auto"
                  Padding="25,0,25,0"
                  RowSpacing="0">
                <!-- EMAIL -->
                <Label Text="Enter you'r Email"
                        TextColor="{StaticResource Black}" 
                       Grid.Row="0"
                       Padding="0,0,0,0"/>
                
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto">
                    <!-- EMAIL ENTRY -->
                    <Entry Grid.Column="0"
                           Placeholder="Example@gmail.com"
                           FontSize="16"
                           BackgroundColor="Transparent"/>

                    <!-- GET OTP BUTTON -->
                    <Button Grid.Column="1"
                            Text="Get OTP?"
                            FontSize="14"
                            BackgroundColor="{StaticResource News}"
                            TextColor="{StaticResource TabUnselected}"
                            CornerRadius="15"
                            Padding="10,0,10,0"
                            VerticalOptions="Center"/>
              
                </Grid>

                <Label
                    Text="Verification Code"
                    Grid.Row="2"
                    Margin="0,20,0,0"
                    TextColor="{StaticResource Black}"/>

                <Entry  
                    Placeholder="Enter Verification Code"
                    Grid.Row="3"
                    Keyboard="Email"
                    FontSize="16"
                    BackgroundColor="Transparent"
                    />


            </Grid>
            
            
            <!--VERIFY-->

            <Button Grid.Row="3"
                    Text="Verify"
                    BackgroundColor="{StaticResource News}"
                    TextColor="{StaticResource TabUnselected}"
                    FontSize="20"
                    FontAttributes="Bold"
                    CornerRadius="30"
                    HeightRequest="60"
                    WidthRequest="150"
                    HorizontalOptions="Center"
                    Margin="0,50,0,0"
                    Clicked="verify"
                    >

                <Button.Shadow>
                    <Shadow Brush="#40000000"
                            Offset="0,5"
                            Radius="10"
                            Opacity="0.8"/>
                </Button.Shadow>

            </Button>
        </Grid>
        
    </VerticalStackLayout>
</ContentPage>