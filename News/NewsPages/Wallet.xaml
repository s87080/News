<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="News.NewsPages.Wallet"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BgColor}"
             Title="Wallet">

    <ScrollView>
        <Grid Padding="15" RowSpacing="20">

            <!-- ROW DEFINITIONS -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Balance -->
                <RowDefinition Height="Auto"/>
                <!-- Quick -->
                <RowDefinition Height="Auto"/>
                <!-- Title -->
                <RowDefinition Height="*"/>
                <!-- List -->
            </Grid.RowDefinitions>

            <!-- 🔷 HEADER -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <Label Text="My Wallet"
                       FontSize="22"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>

                <Image Source="bell.png"
                       HeightRequest="24"
                       WidthRequest="24"
                       Grid.Column="1"/>
            </Grid>

            <!-- 🔷 BALANCE CARD -->
            <Frame Grid.Row="1"
                   CornerRadius="25"
                   Padding="20"
                   HasShadow="True">

                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#007BC0" Offset="0"/>
                        <GradientStop Color="#00AEEF" Offset="1"/>
                    </LinearGradientBrush>
                </Frame.Background>

                <Grid RowDefinitions="Auto,Auto,Auto">

                    <Label Text="₹ 1,250.00"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label Text="Available Balance"
                           Grid.Row="1"
                           TextColor="White"
                           Opacity="0.8"/>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="10"
                          Margin="0,15,0,0">

                        <Button Text="+ Add Money"
                                BackgroundColor="White"
                                TextColor="#007BC0"
                                CornerRadius="20"
                                HeightRequest="40"/>

                        <Button Text="Withdraw"
                                Grid.Column="1"
                                BackgroundColor="#005A8C"
                                TextColor="White"
                                CornerRadius="20"
                                HeightRequest="40"/>

                    </Grid>

                </Grid>
            </Frame>

            <!-- 🔷 QUICK ACTIONS -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="10">

                <Frame CornerRadius="15" BackgroundColor="White">
                    <Grid RowDefinitions="Auto,Auto" Padding="0,10,0,10">
                        <Image Source="add.png"
                               HeightRequest="28"
                               HorizontalOptions="Center"/>
                        <Label Text="Add Money"
                               Grid.Row="1"
                               FontSize="12"
                               HorizontalOptions="Center"/>
                    </Grid>
                </Frame>

                <Frame Grid.Column="1" CornerRadius="15" BackgroundColor="White">
                    <Grid RowDefinitions="Auto,Auto" Padding="10">
                        <Image Source="gift.png"
                               HeightRequest="28"
                               HorizontalOptions="Center"/>
                        <Label Text="Rewards"
                               Grid.Row="1"
                               FontSize="12"
                               HorizontalOptions="Center"/>
                    </Grid>
                </Frame>

                <Frame Grid.Column="2" CornerRadius="15" BackgroundColor="White">
                    <Grid RowDefinitions="Auto,Auto" Padding="10">
                        <Image Source="creditcard.png"
                               HeightRequest="28"
                               HorizontalOptions="Center"/>
                        <Label Text="Cards"
                               Grid.Row="1"
                               FontSize="12"
                               HorizontalOptions="Center"/>
                    </Grid>
                </Frame>

            </Grid>

            <!-- 🔷 TITLE -->
            <Label Grid.Row="3"
                   Text="Recent Transactions"
                   FontSize="16"
                   FontAttributes="Bold"/>

            <!-- 🔷 TRANSACTIONS -->
            <CollectionView Grid.Row="4">

                <CollectionView.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Added ₹500</x:String>
                        <x:String>Subscription ₹200</x:String>
                        <x:String>Added ₹1000</x:String>
                        <x:String>Recharge ₹150</x:String>
                    </x:Array>
                </CollectionView.ItemsSource>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Frame CornerRadius="12"
                               Margin="0,5"
                               BackgroundColor="White"
                               HasShadow="True">

                            <Grid Padding="10"
                                  ColumnDefinitions="Auto,*,Auto">

                                <Image Source="money.png"
                                       HeightRequest="22"
                                       WidthRequest="22"/>

                                <Grid Grid.Column="1"
                                      RowDefinitions="Auto,Auto"
                                      Margin="10,0">

                                    <Label Text="{Binding .}"
                                           FontSize="14"/>

                                    <Label Text="Today"
                                           Grid.Row="1"
                                           FontSize="12"
                                           Opacity="0.6"/>
                                </Grid>

                                <Label Text="+ ₹500"
                                       Grid.Column="2"
                                       TextColor="Green"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>

                            </Grid>

                        </Frame>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>
    </ScrollView>
</ContentPage>