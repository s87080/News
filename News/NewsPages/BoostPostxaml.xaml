<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="News.NewsPages.BoostPostxaml"
             Title="BoostPostxaml"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BgColor}">
    <ScrollView>
        <Grid Padding="15"
              RowSpacing="20"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

            <!-- 🔷 HEADER -->
            <Label Grid.Row="0"
                   Text="🚀 Boost Your Post"
                   FontSize="22"
                   FontAttributes="Bold"/>

            <!-- 🔷 INFO CARD -->
            <Frame Grid.Row="1"
                   CornerRadius="20"
                   Padding="15"
                   BackgroundColor="{StaticResource News}">

                <VerticalStackLayout>
                    <Label Text="Reach More Audience"
                           FontSize="18"
                           TextColor="White"
                           FontAttributes="Bold"/>

                    <Label Text="Promote your post to get more views, likes and engagement."
                           TextColor="White"
                           FontSize="13"
                           Opacity="0.8"/>
                </VerticalStackLayout>
            </Frame>

            <!-- 🔷 PLAN TITLE -->
            <Label Grid.Row="2"
                   Text="Select Plan"
                   FontAttributes="Bold"/>

            <!-- 🔷 PLANS -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="10">

                <!-- Basic -->
                <Frame CornerRadius="15" BackgroundColor="White" Padding="15">
                    <!--<Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBasicTapped"/>
                    </Frame.GestureRecognizers>-->

                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="Basic"/>
                        <Label Text="₹49" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Standard -->
                <Frame Grid.Column="1"
                       CornerRadius="15"
                       BackgroundColor="{StaticResource News}"
                       Padding="15">
                    <!--<Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStandardTapped"/>
                    </Frame.GestureRecognizers>-->

                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="Standard" TextColor="White"/>
                        <Label Text="₹99"
                               TextColor="White"
                               FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Premium -->
                <Frame Grid.Column="2"
                       CornerRadius="15"
                       BackgroundColor="White"
                       Padding="15">
                    <!--<Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPremiumTapped"/>
                    </Frame.GestureRecognizers>-->

                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="Premium"/>
                        <Label Text="₹199" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- 🔷 DURATION TITLE -->
            <Label Grid.Row="4"
                   Text="Duration"
                   FontAttributes="Bold"/>

            <!-- 🔷 DURATION -->
            <Grid Grid.Row="5"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="10">

                <Button Text="1 Day"
                        CornerRadius="20"
                        BackgroundColor="{StaticResource labelBg}"
                        TextColor="{StaticResource Black}"/>

                <Button Text="3 Days"
                        Grid.Column="1"
                        CornerRadius="20"
                        BackgroundColor="{StaticResource News}"
                        TextColor="White"/>

                <Button Text="7 Days"
                        Grid.Column="2"
                        CornerRadius="20"
                        BackgroundColor="{StaticResource labelBg}"
                        TextColor="{StaticResource Black}"/>
            </Grid>

            <!-- 🔷 AUDIENCE TITLE -->
            <Label Grid.Row="6"
                   Text="Audience"
                   FontAttributes="Bold"/>

            <!-- 🔷 AUDIENCE -->
            <Grid Grid.Row="7"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="10">

                <Button Text="All"
                        BackgroundColor="{StaticResource News}"
                        TextColor="White"
                        CornerRadius="20"/>

                <Button Text="Local"
                        Grid.Column="1"
                        BackgroundColor="{StaticResource labelBg}"
                        CornerRadius="20"
                        TextColor="{StaticResource Black}"/>

                <Button Text="Category"
                        Grid.Column="2"
                        BackgroundColor="{StaticResource labelBg}"
                        CornerRadius="20"
                        TextColor="{StaticResource Black}"/>
            </Grid>

            <!-- 🔷 BUTTON -->
            <Button Grid.Row="8"
                    Text="🚀 Boost Now"
                    BackgroundColor="{StaticResource News}"
                    TextColor="White"
                    FontSize="18"
                    CornerRadius="30"
                    HeightRequest="60"
                    Margin="0,20,0,40"
                    Clicked="BoostNow"/>

        </Grid>
    </ScrollView>

</ContentPage>